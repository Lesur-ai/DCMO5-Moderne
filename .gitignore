.DS_Store

# Go build/test outputs
/bin/
/dist/
/coverage.out
*.test
/.tmp/
# Binaires compilés à la racine (go build sans -o → nom du module/dossier)
/main
/dcmo5

# Legacy DCMO5 v11 reference tree.
# Keep it local until the license/import audit decides what can be tracked.
/dcmo5v11.0/

# Sources de référence Thomson (audit v2/v3) — émulateurs C GPLv3 de D. Coulom
# (dcto8d.2009.05, dcto9p v11). Gardées locales comme dcmo5v11.0, en attente de
# la décision licence/import.
/dcto8d200905/
/dcto9/

# Répertoire de travail local
chantier

# Runtime files generated by the legacy emulator
/dcmo5.ini
/dcmo5-printer.txt

# Enregistrements audio de diagnostic (ne pas versionner)
*.m4a
*.wav

# Note : rom/ (ROM système MO5 + contrôleur CD90-640) et software/ (logiciels
